# Copy these into Vercel → Project → Settings → Environment Variables.
# Run `node scripts/print-vercel-env.mjs` locally to print ready-to-paste values.

# Required — Firebase Web API key (server-only; used for email/password login)
FIREBASE_API_KEY=

# Required on Vercel — paste the full service account JSON on one line:
FIREBASE_SERVICE_ACCOUNT_JSON=

# Local dev alternative — path to service account JSON (credentials/ is gitignored):
# FIREBASE_SERVICE_ACCOUNT_PATH=./credentials/your-service-account.json

# Or set these three instead of FIREBASE_SERVICE_ACCOUNT_JSON:
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=

# Optional — enables the AI chat assistant:
OPENAI_API_KEY=

# Optional overrides for non-OpenAI providers:
# NVIDIA_API_KEY=
# OPENAI_BASE_URL=
# OPENAI_MODEL=
