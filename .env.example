# Copy these into Vercel → Project → Settings → Environment Variables.
# Required for auth and data storage:

# Firebase Web API key (server-only; used for email/password login)
FIREBASE_API_KEY=

# Firebase Admin — paste the full service account JSON on one line, or use the three vars below:
FIREBASE_SERVICE_ACCOUNT_JSON=
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=

# Optional — enables the AI chat assistant:
OPENAI_API_KEY=

# Optional overrides for non-OpenAI providers:
# NVIDIA_API_KEY=
# OPENAI_BASE_URL=
# OPENAI_MODEL=
